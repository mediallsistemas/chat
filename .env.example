# Database
DATABASE_URL="postgresql://mediall:password@localhost:5432/mediall_db"

# Redis (used by BullMQ and cache)
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# JWT — OBRIGATÓRIO — gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-secret-in-production-min-64-chars"
JWT_EXPIRES_IN="15m"
# OBRIGATÓRIO — secret diferente do access token
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production-min-64-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# CSRF — OBRIGATÓRIO — gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET="change-this-csrf-secret-in-production"

# Backend
BACKEND_PORT=4000
NODE_ENV=development

# Frontend (used for CORS)
FRONTEND_URL="http://localhost:3000"

# Next.js public env (prefix NEXT_PUBLIC_ required)
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# MinIO object storage
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="mediall-files"

# LiveKit video (generate keys: livekit-server generate-keys)
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"
LIVEKIT_WS_URL="ws://localhost:7880"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@mediallbrasil.com.br"

# Web Push / VAPID (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:mediallsistemas@gmail.com"

# Sentry error tracking (optional — leave blank to disable)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# E2E tests only
TEST_ADMIN_EMAIL=""
TEST_ADMIN_PASSWORD=""
