generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UnitType {
  MATRIZ
  UNIDADE
}

enum UserRole {
  SUPER_ADMIN
  DIRETORIA
  GESTOR
  COLABORADOR
  VISUALIZADOR
}

enum AccessScope {
  GLOBAL
  MULTI
  SINGLE
}

enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  DONE
}

enum PhaseStatus {
  LOCKED
  ACTIVE
  ARCHIVED
}

enum TrafficLight {
  GREEN
  YELLOW
  RED
}

enum Direction {
  UP
  DOWN
}

enum CalcMethod {
  SUM
  PERCENTAGE
  BINARY
}

enum UnitScope {
  ALL
  SPECIFIC
  MATRIX
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AcceptanceStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ImpedimentStatus {
  BLOCKED
  ATTENTION
  RESOLVED
}

enum BoardOwner {
  GROUP
  MACRO_TASK
  PHASE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_OVERDUE
  TASK_DUE_SOON
  IMPEDIMENT_CREATED
  IMPEDIMENT_ESCALATED
  IMPEDIMENT_RESOLVED
  PHASE_UNLOCKED
  PHASE_COMPLETED
  MENTION
  MEETING_REMINDER
  CHECKIN_REQUEST
  GOAL_AT_RISK
  TRANSCRIPT_READY
  TICKET_ASSIGNED
  TICKET_UPDATED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GroupType {
  GENERAL
  SECTOR
  SUBSECTOR
  PROJECT
  TEMPORARY
  PRIVATE
}

enum GroupMemberRole {
  ADMIN
  MEMBER
  VIEWER
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum ConsentType {
  DATA_PROCESSING
  PUSH_NOTIFICATIONS
  EMAIL_COMMUNICATIONS
  ANALYTICS
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
  ATTENDED
}

// ─── Units & Users ────────────────────────────────────────────────────────────

model Unit {
  id        String   @id @default(uuid())
  name      String
  type      UnitType
  parentId  String?  @map("parent_id")
  managerId String   @map("manager_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  parent   Unit?  @relation("UnitHierarchy", fields: [parentId], references: [id])
  children Unit[] @relation("UnitHierarchy")
  manager  User   @relation("UnitManager", fields: [managerId], references: [id])

  userUnits        UserUnit[]
  strategicPlans   StrategicPlan[]
  groups           Group[]
  meetings         Meeting[]
  documentFolders  DocumentFolder[]
  documents        Document[]
  tickets          Ticket[]

  @@map("units")
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String      @map("password_hash")
  avatarUrl    String?     @map("avatar_url")
  phone        String?
  accessScope  AccessScope @map("access_scope")
  isActive     Boolean     @default(true) @map("is_active")
  failedLogins Int         @default(0) @map("failed_logins")
  lockedAt     DateTime?   @map("locked_at")
  lastSeenAt   DateTime?   @map("last_seen_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  unitAccess           UserUnit[]
  managedUnits         Unit[]               @relation("UnitManager")
  auditLogs            AuditLog[]
  notificationSetting  NotificationSetting?
  pushSubscriptions    PushSubscription[]
  consents             UserConsent[]
  sentMessages         Message[]            @relation("MessageSender")
  messageReactions     MessageReaction[]
  createdMeetings      Meeting[]            @relation("MeetingCreator")
  uploadedDocuments    Document[]           @relation("DocumentUploader")
  reportedTickets      Ticket[]             @relation("TicketReporter")
  assignedTickets      Ticket[]             @relation("TicketAssignee")
  ticketComments       TicketComment[]

  @@map("users")
}

model UserUnit {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  unitId    String    @map("unit_id")
  role      UserRole
  isPrimary Boolean   @default(false) @map("is_primary")
  grantedBy String    @map("granted_by")
  grantedAt DateTime  @default(now()) @map("granted_at")
  expiresAt DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
  @@map("user_units")
}

// ─── Strategic Planning ───────────────────────────────────────────────────────

model StrategicPlan {
  id        String     @id @default(uuid())
  name      String
  year      Int
  vision    String?
  mission   String?
  values    String?
  status    PlanStatus @default(DRAFT)
  unitId    String     @map("unit_id")
  createdBy String     @map("created_by")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  unit       Unit        @relation(fields: [unitId], references: [id])
  objectives Objective[]

  @@map("strategic_plans")
}

model Objective {
  id                  String       @id @default(uuid())
  planId              String       @map("plan_id")
  title               String
  description         String?
  benefits            String?
  responsibleSectorId String?      @map("responsible_sector_id")
  responsibleUserId   String       @map("responsible_user_id")
  deadline            DateTime
  status              GoalStatus   @default(NOT_STARTED)
  progressPct         Decimal      @default(0) @map("progress_pct")
  trafficLight        TrafficLight @default(GREEN) @map("traffic_light")
  groupId             String?      @map("group_id")
  unitId              String       @map("unit_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  plan  StrategicPlan @relation(fields: [planId], references: [id])
  goals Goal[]

  @@map("objectives")
}

model Goal {
  id           String     @id @default(uuid())
  objectiveId  String     @map("objective_id")
  title        String
  description  String?
  sectorId     String?    @map("sector_id")
  investment   Decimal?
  direction    Direction
  calcMethod   CalcMethod @map("calc_method")
  targetValue  Decimal?   @map("target_value")
  currentValue Decimal    @default(0) @map("current_value")
  initialValue Decimal    @default(0) @map("initial_value")
  status       GoalStatus @default(NOT_STARTED)
  progressPct  Decimal    @default(0) @map("progress_pct")
  unitId       String     @map("unit_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  objective Objective   @relation(fields: [objectiveId], references: [id])
  phases    PlanPhase[]

  @@map("goals")
}

model PlanPhase {
  id                String      @id @default(uuid())
  goalId            String      @map("goal_id")
  title             String
  description       String?
  order             Int
  status            PhaseStatus @default(LOCKED)
  unitScope         UnitScope   @default(ALL) @map("unit_scope")
  unitId            String?     @map("unit_id")
  responsibleUserId String      @map("responsible_user_id")
  startDate         DateTime?   @map("start_date")
  dueDate           DateTime?   @map("due_date")
  completedAt       DateTime?   @map("completed_at")
  kanbanBoardId     String      @map("kanban_board_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  goal        Goal        @relation(fields: [goalId], references: [id])
  kanbanBoard KanbanBoard @relation(fields: [kanbanBoardId], references: [id])
  macroTasks  MacroTask[]

  @@map("plan_phases")
}

model MacroTask {
  id                String     @id @default(uuid())
  phaseId           String     @map("phase_id")
  goalId            String     @map("goal_id")
  objectiveId       String     @map("objective_id")
  title             String
  description       String?
  responsibleUserId String     @map("responsible_user_id")
  sectorId          String?    @map("sector_id")
  unitId            String     @map("unit_id")
  startDate         DateTime?  @map("start_date")
  dueDate           DateTime?  @map("due_date")
  status            TaskStatus @default(NOT_STARTED)
  progressPct       Decimal    @default(0) @map("progress_pct")
  groupId           String?    @map("group_id")
  kanbanBoardId     String     @map("kanban_board_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  phase       PlanPhase   @relation(fields: [phaseId], references: [id])
  kanbanBoard KanbanBoard @relation(fields: [kanbanBoardId], references: [id])

  @@map("macro_tasks")
}

// ─── Kanban ───────────────────────────────────────────────────────────────────

model KanbanBoard {
  id        String     @id @default(uuid())
  name      String
  ownerType BoardOwner @map("owner_type")
  ownerId   String     @map("owner_id")
  unitId    String     @map("unit_id")
  createdAt DateTime   @default(now()) @map("created_at")

  columns    KanbanColumn[]
  tasks      Task[]
  planPhases PlanPhase[]
  macroTasks MacroTask[]

  @@map("kanban_boards")
}

model KanbanColumn {
  id           String   @id @default(uuid())
  boardId      String   @map("board_id")
  name         String
  position     Int
  wipLimit     Int?     @map("wip_limit")
  isDoneColumn Boolean  @default(false) @map("is_done_column")
  color        String?
  createdAt    DateTime @default(now()) @map("created_at")

  board KanbanBoard @relation(fields: [boardId], references: [id])
  tasks Task[]

  @@map("kanban_columns")
}

model Task {
  id                String           @id @default(uuid())
  boardId           String           @map("board_id")
  columnId          String           @map("column_id")
  macroTaskId       String?          @map("macro_task_id")
  title             String
  description       String?
  responsibleUserId String           @map("responsible_user_id")
  createdBy         String           @map("created_by")
  priority          Priority         @default(MEDIUM)
  startDate         DateTime?        @map("start_date")
  dueDate           DateTime?        @map("due_date")
  estimatedHours    Decimal?         @map("estimated_hours")
  actualHours       Decimal?         @map("actual_hours")
  position          Int
  isBlocked         Boolean          @default(false) @map("is_blocked")
  acceptanceStatus  AcceptanceStatus @default(PENDING) @map("acceptance_status")
  unitId            String           @map("unit_id")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  completedAt       DateTime?        @map("completed_at")

  board      KanbanBoard      @relation(fields: [boardId], references: [id])
  column     KanbanColumn     @relation(fields: [columnId], references: [id])
  impediments  TaskImpediment[]
  checklists   TaskChecklist[]
  files        TaskFile[]
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")

  @@index([columnId, position])
  @@index([responsibleUserId, completedAt])
  @@map("tasks")
}

model TaskDependency {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  dependsOnId String   @map("depends_on_id")
  createdAt   DateTime @default(now()) @map("created_at")

  task      Task @relation("TaskDependencies", fields: [taskId], references: [id])
  dependsOn Task @relation("TaskDependents", fields: [dependsOnId], references: [id])

  @@unique([taskId, dependsOnId])
  @@map("task_dependencies")
}

model TaskImpediment {
  id                       String           @id @default(uuid())
  taskId                   String           @map("task_id")
  reportedBy               String           @map("reported_by")
  description              String
  responsibleForResolution String           @map("responsible_for_resolution")
  expectedResolutionDate   DateTime         @map("expected_resolution_date")
  status                   ImpedimentStatus @default(BLOCKED)
  resolvedBy               String?          @map("resolved_by")
  resolutionNotes          String?          @map("resolution_notes")
  escalationLevel          Int              @default(0) @map("escalation_level")
  unitId                   String           @map("unit_id")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")
  resolvedAt               DateTime?        @map("resolved_at")

  task Task @relation(fields: [taskId], references: [id])

  @@index([unitId, status])
  @@index([unitId, createdAt])
  @@index([escalationLevel])
  @@map("task_impediments")
}

model TaskChecklist {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  description String
  isDone      Boolean  @default(false) @map("is_done")
  createdAt   DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_checklists")
}

model TaskFile {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  fileKey      String   @map("file_key")
  fileName     String   @map("file_name")
  fileSize     Int      @map("file_size")
  fileMime     String   @map("file_mime")
  uploadedBy   String   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_files")
}

// ─── Communication ────────────────────────────────────────────────────────────

model Group {
  id             String    @id @default(uuid())
  name           String
  description    String?
  type           GroupType
  parentId       String?   @map("parent_id")
  sectorId       String?   @map("sector_id")
  objectiveId    String?   @map("objective_id")
  unitId         String    @map("unit_id")
  createdBy      String    @map("created_by")
  avatarUrl      String?   @map("avatar_url")
  isArchived     Boolean   @default(false) @map("is_archived")
  archiveAt      DateTime? @map("archive_at")
  kanbanBoardId  String    @map("kanban_board_id")
  onlyAdminsPost Boolean   @default(false) @map("only_admins_post")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  unit     Unit          @relation(fields: [unitId], references: [id])
  members  GroupMember[]
  messages Message[]
  meetings Meeting[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(uuid())
  groupId  String          @map("group_id")
  userId   String          @map("user_id")
  role     GroupMemberRole @default(MEMBER)
  isMuted  Boolean         @default(false) @map("is_muted")
  joinedAt DateTime        @default(now()) @map("joined_at")
  addedBy  String          @map("added_by")

  group Group @relation(fields: [groupId], references: [id])

  @@unique([groupId, userId])
  @@map("group_members")
}

model Message {
  id        String      @id @default(uuid())
  groupId   String      @map("group_id")
  senderId  String      @map("sender_id")
  content   String
  type      MessageType @default(TEXT)
  replyToId String?     @map("reply_to_id")
  fileKey   String?     @map("file_key")
  fileName  String?     @map("file_name")
  fileSize  Int?        @map("file_size")
  fileMime  String?     @map("file_mime")
  isPinned  Boolean     @default(false) @map("is_pinned")
  isEdited  Boolean     @default(false) @map("is_edited")
  editedAt  DateTime?   @map("edited_at")
  isDeleted Boolean     @default(false) @map("is_deleted")
  deletedAt DateTime?   @map("deleted_at")
  createdAt DateTime    @default(now()) @map("created_at")

  group     Group             @relation(fields: [groupId], references: [id])
  sender    User              @relation("MessageSender", fields: [senderId], references: [id])
  replyTo   Message?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]         @relation("MessageReplies")
  reactions MessageReaction[]

  @@index([groupId, createdAt])
  @@index([groupId, isPinned])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ─── Meetings ─────────────────────────────────────────────────────────────────

model Meeting {
  id              String        @id @default(uuid())
  title           String
  description     String?
  groupId         String?       @map("group_id")
  unitId          String        @map("unit_id")
  createdBy       String        @map("created_by")
  startAt         DateTime      @map("start_at")
  endAt           DateTime      @map("end_at")
  roomId          String        @map("room_id")
  isRecurring     Boolean       @default(false) @map("is_recurring")
  recurrenceRule  String?       @map("recurrence_rule")
  parentMeetingId String?       @map("parent_meeting_id")
  status                MeetingStatus @default(SCHEDULED)
  recordingUrl          String?       @map("recording_url")
  transcript            String?
  transcriptSummary     String?       @map("transcript_summary")
  transcriptActionItems Json?         @map("transcript_action_items")
  transcriptedAt        DateTime?     @map("transcripted_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  unit         Unit                 @relation(fields: [unitId], references: [id])
  creator      User                 @relation("MeetingCreator", fields: [createdBy], references: [id])
  group        Group?               @relation(fields: [groupId], references: [id])
  participants MeetingParticipant[]

  @@map("meetings")
}

model MeetingParticipant {
  id        String            @id @default(uuid())
  meetingId String            @map("meeting_id")
  userId    String            @map("user_id")
  status    ParticipantStatus @default(INVITED)
  joinedAt  DateTime?         @map("joined_at")
  leftAt    DateTime?         @map("left_at")

  meeting Meeting @relation(fields: [meetingId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

// ─── Notification Settings ────────────────────────────────────────────────────

model NotificationSetting {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  dndEnabled   Boolean  @default(false) @map("dnd_enabled")
  dndStart     String?  @map("dnd_start")
  dndEnd       String?  @map("dnd_end")
  emailEnabled Boolean  @default(true) @map("email_enabled")
  emailTypes   String[] @map("email_types")
  pushEnabled  Boolean  @default(true) @map("push_enabled")

  user User @relation(fields: [userId], references: [id])

  @@map("notification_settings")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  title      String
  body       String
  type       NotificationType
  entityType String?          @map("entity_type")
  entityId   String?          @map("entity_id")
  unitId     String?          @map("unit_id")
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at")
  expiresAt  DateTime?        @map("expires_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([unitId, createdAt])
  @@map("notifications")
}

model UserConsent {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  type       ConsentType
  accepted   Boolean
  ip         String?
  userAgent  String?     @map("user_agent")
  version    String      @default("1.0")
  acceptedAt DateTime    @default(now()) @map("accepted_at")
  revokedAt  DateTime?   @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type, version])
  @@index([userId])
  @@map("user_consents")
}

// ─── Document Center ─────────────────────────────────────────────────────────

model DocumentFolder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?  @map("parent_id")
  unitId    String   @map("unit_id")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderTree")
  unit      Unit             @relation(fields: [unitId], references: [id])
  documents Document[]

  @@index([unitId])
  @@map("document_folders")
}

model Document {
  id          String   @id @default(uuid())
  name        String
  description String?
  folderId    String?  @map("folder_id")
  unitId      String   @map("unit_id")
  fileKey     String   @map("file_key")
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size")
  fileMime    String   @map("file_mime")
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  folder   DocumentFolder? @relation(fields: [folderId], references: [id])
  unit     Unit            @relation(fields: [unitId], references: [id])
  uploader User            @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([unitId, folderId])
  @@index([unitId, createdAt])
  @@map("documents")
}

// ─── Internal Ticketing ───────────────────────────────────────────────────────

model Ticket {
  id          String         @id @default(uuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  unitId      String         @map("unit_id")
  reportedBy  String         @map("reported_by")
  assignedTo  String?        @map("assigned_to")
  resolvedAt  DateTime?      @map("resolved_at")
  closedAt    DateTime?      @map("closed_at")
  dueDate     DateTime?      @map("due_date")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  unit     Unit            @relation(fields: [unitId], references: [id])
  reporter User            @relation("TicketReporter", fields: [reportedBy], references: [id])
  assignee User?           @relation("TicketAssignee", fields: [assignedTo], references: [id])
  comments TicketComment[]

  @@index([unitId, status])
  @@index([unitId, priority])
  @@index([unitId, createdAt])
  @@index([assignedTo, status])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  userId     String   @map("user_id")
  content    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("ticket_comments")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  unitId     String?  @map("unit_id")
  action     String
  entityId   String?  @map("entity_id")
  entityType String?  @map("entity_type")
  metadata   Json?
  ipAddress  String   @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([unitId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
