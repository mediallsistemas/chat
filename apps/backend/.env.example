# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mediall_db"

# Redis (used by BullMQ, cache, and Redis Streams for cross-service events)
# Production must use Redis 5+ for Streams support.
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (generate strong secrets in production: openssl rand -hex 64)
JWT_SECRET=
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN="7d"

# CSRF
CSRF_SECRET=

# Backend
BACKEND_PORT=4000
NODE_ENV=development

# Frontend (used for CORS)
FRONTEND_URL="http://localhost:3002"

# Next.js public env
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# MinIO object storage
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="mediall-files"

# LiveKit video
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL="ws://localhost:7880"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@mediallbrasil.com.br"

# Web Push / VAPID (generate via: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Anthropic Claude (used for inline transcription processing OR by transcription-svc)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Modular Monolith (plano 17) ─────────────────────────────────────────────

# Shared token for internal service-to-service HTTP calls (e.g. transcription-svc
# calling GET /internal/v1/meetings/:id on the monolith). Must match the value
# in transcription-svc's environment.
MONOLITH_INTERNAL_TOKEN=

# Feature flag: when true, transcription requests are dispatched to
# transcription-svc via Redis Streams instead of processed inline. Set to
# false to revert to inline processing without redeploying the svc.
TRANSCRIPTION_SVC_ENABLED=false

# E2E tests
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
