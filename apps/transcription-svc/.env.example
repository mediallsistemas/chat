# Redis (must support Streams; production uses Redis 7+)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Monolith internal API (for fetching meeting metadata)
MONOLITH_INTERNAL_URL=http://localhost:4000
# Must match MONOLITH_INTERNAL_TOKEN in backend's .env
MONOLITH_INTERNAL_TOKEN=

# Consumer behavior
CONSUMER_NAME=transcription-local
POLL_BLOCK_MS=5000
MAX_RETRIES=3

# Logging
LOG_LEVEL=info
